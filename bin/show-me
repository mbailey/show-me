#!/usr/bin/env bash
set -o nounset -o pipefail -o errexit

# show-me - Display files, URLs, or command output for the user
#
# Part of the show-me package for visual context sharing
# between AI assistants and users.

VERSION="3.0.1"

# Configuration with defaults
SHOW_SESSION="${SHOW_SESSION:-}"  # Empty = auto-detect current session
SHOW_WINDOW="${SHOW_WINDOW:-show}"
SHOW_BROWSER="${SHOW_BROWSER:-}"  # Empty means auto-detect
SHOW_AUTO_ATTACH="${SHOW_AUTO_ATTACH:-true}"
SHOW_FOCUS="${SHOW_FOCUS:-true}"
SHOW_ZOOM="${SHOW_ZOOM:-true}"
SHOW_LAYOUT="${SHOW_LAYOUT:-}"  # Empty resolves to 'stacked' in main() (SHOW-86). Explicit SHOW_LAYOUT=window restores the historical separate-window behavior.
SHOW_SPLIT_SIZE="${SHOW_SPLIT_SIZE:-}"  # Split pane percentage (default: 70% side, 30% top/bottom)
SHOW_FORMAT="${SHOW_FORMAT:-human}"  # Output format for cmd: handle. human = readable line + [pane %NN]; json = one-line machine handle (SHOW-92)

# Get private socket directory for security
# Returns user-private directory instead of world-readable /tmp
get_socket_dir() {
  if [[ -n "${TMPDIR:-}" && -d "$TMPDIR" ]]; then
    echo "$TMPDIR"
  elif [[ -n "${XDG_RUNTIME_DIR:-}" && -d "$XDG_RUNTIME_DIR" ]]; then
    echo "$XDG_RUNTIME_DIR"
  else
    local fallback="$HOME/.local/run"
    mkdir -p "$fallback" && chmod 700 "$fallback"
    echo "$fallback"
  fi
}

# Get target tmux session based on configuration and context
# Priority: 1. Explicit flag, 2. Env var, 3. Current session, 4. Attached, 5. Any, 6. Create
get_target_session() {
  local explicit_session="${1:-}"

  # Priority 1 & 2: Explicit flag or env var (already resolved by caller)
  if [[ -n "$explicit_session" ]]; then
    echo "$explicit_session"
    return 0
  fi

  # Priority 3: Current tmux session (if running inside tmux)
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{session_name}'
    return 0
  fi

  # Priority 4: First attached session (visible to user)
  local attached
  attached=$(tmux list-sessions -F '#{session_name} #{session_attached}' 2>/dev/null \
    | awk '$2 > 0 {print $1; exit}')
  if [[ -n "$attached" ]]; then
    echo "$attached"
    return 0
  fi

  # Priority 5: Any existing session
  local any_session
  any_session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | head -1)
  if [[ -n "$any_session" ]]; then
    echo "$any_session"
    return 0
  fi

  # Priority 6: Create new session (let tmux name it)
  tmux new-session -d -n "$SHOW_WINDOW" 2>/dev/null
  tmux list-sessions -F '#{session_name}' | head -1
}

show_help() {
  cat <<EOF
Usage: show-me <target> [OPTIONS]

Display content for the user to view.

Targets:
  <file>                   Open file in Neovim
  <file>:<line>            Open file at specific line
  <file>:<start>-<end>     Open file highlighting line range
  <file>#L<line>           Open file at specific line (URL fragment style)
  <file>#L<start>-<end>    Open file highlighting line range
  http://... https://...   Open URL in browser
  cmd:<command>            Run command in shell pane
  pane:<id>                Focus tmux pane by ID (cross-session)
  pane:self                Focus the current pane (agent self-focus)
  diff                     Open DiffView (unstaged changes)
  diff:<ref>               Open DiffView against ref (branch, commit, range)
  diff:<ref> -- <path>     Open DiffView scoped to path

Options:
  -s, --session NAME       Use specific tmux session
  -w, --window NAME        Use specific window name (default: show)
  -p, --pane ID            Target specific pane ID
  --layout VALUE           Layout mode: right, below, left, above, window, stacked
                           Default: stacked. Overrides SHOW_LAYOUT env var.
  --restack [LAYOUT]       Re-apply a layout to the panes already in the window,
                           then exit — creates no new pane and shows nothing.
                           LAYOUT is optional and accepts the same values as
                           --layout; when omitted, uses the configured default
                           layout (SHOW_LAYOUT, 'stacked' when unset).
  --here                   Show in a split pane (shorthand for content-type default
                           direction: right for files, below for commands)
  --format VALUE           cmd: output format: human (default) or json.
                           human appends [pane %NN] to the line; json emits a
                           one-line machine-readable handle. Overrides SHOW_FORMAT.
  --no-focus               Don't switch focus to show window
  --no-zoom                Don't zoom the pane after showing
  --no-attach              Don't auto-attach terminal if no clients
  --hold SECONDS           Hold visual focus for N seconds (default: 30)
                           Prevents VoiceMode auto-focus from switching away
  -h, --help               Show this help
  -V, --version            Show version

Behavior:
  By default, show-me uses the 'stacked' layout: a leader pane on the left
  with content panes accumulating to the right. File shows reuse the
  existing Neovim pane; command shows create a new pane each call.

  Set SHOW_LAYOUT=window (or pass --layout window) to use the historical
  behavior — content goes into a separate "show" window of your tmux
  session. If you're not in tmux, show-me uses an attached session, or
  creates one if none exist.

  Use --restack to tidy panes that have drifted (manually split, closed,
  or resized) back into a layout without creating a new pane. It takes no
  target; with no LAYOUT argument it re-applies the configured default
  layout (SHOW_LAYOUT, 'stacked' when unset). Must run inside tmux.

  See docs/layouts.md for the full layout reference.

  All focus commands support cross-session switching. If the target pane
  or window is in a different tmux session, show-me will switch the client
  to that session before selecting the window and pane.

  show-me only connects to Neovim instances it created, using sockets in a
  private directory for security.

Examples:
  show-me README.md                    # Open in current session's show window
  show-me -s main README.md            # Open in "main" session
  show-me -w editor file.txt           # Open in "editor" window
  show-me src/main.py:42               # Open at line 42
  show-me src/main.py:10-20            # Open highlighting lines 10-20
  show-me bin/show-me#L124-162         # Highlight function definition
  show-me https://github.com           # Open in browser
  show-me "cmd:git status"             # Show git status
  show-me --no-zoom file.txt           # Open without zooming pane
  show-me pane:self                    # Focus agent's own pane
  show-me pane:42                      # Focus pane %42 (even across sessions)
  show-me diff                         # DiffView of unstaged changes
  show-me diff:main                    # DiffView against main branch
  show-me "diff:HEAD~3"                # DiffView of last 3 commits
  show-me "diff:main -- src/"          # DiffView against main, scoped to src/
  show-me --layout right README.md     # Open in split pane to the right
  show-me --layout below "cmd:make"    # Run command in pane below
  show-me --here README.md             # Split pane (default direction for type)
  show-me --restack                    # Re-tidy drifted panes to default layout
  show-me --restack below              # Re-apply the below/horizontal layout
  show-me --format json "cmd:make"     # Run command, emit one-line JSON handle
  show-me --hold 60 README.md          # Hold focus for 60s (long document)

Environment:
  SHOW_SESSION             Target tmux session (default: current/auto-detect)
  SHOW_WINDOW              Target window name (default: show)
  SHOW_BROWSER             Browser for URLs (default: auto-detect)
  SHOW_AUTO_ATTACH         Auto-attach terminal if no clients (default: true)
  SHOW_FOCUS               Switch focus to show window (default: true)
  SHOW_ZOOM                Zoom pane after showing content (default: true)
  SHOW_LAYOUT              Layout mode (default: stacked)
                           Values: right, below, left, above, window, stacked
                           Set to 'window' to restore the pre-2.4 default.
  SHOW_SPLIT_SIZE          Split pane percentage (overrides direction defaults)
                           Defaults: 70% for right/left, 30% for below/above
  SHOW_FORMAT              cmd: output format: human (default) or json

EOF
}

# Parse file:line or file#Lline format with optional line ranges
# Returns: file_path, start_line, and end_line (empty if no line/range)
parse_file_target() {
  local target="$1"
  local file_path=""
  local start_line=""
  local end_line=""

  # Check for range: #L10-20 format (URL fragment style)
  if [[ "$target" =~ ^(.+)#[Ll]([0-9]+)-([0-9]+)$ ]]; then
    file_path="${BASH_REMATCH[1]}"
    start_line="${BASH_REMATCH[2]}"
    end_line="${BASH_REMATCH[3]}"
  # Check for range: :10-20 format
  elif [[ "$target" =~ ^(.+):([0-9]+)-([0-9]+)$ ]]; then
    file_path="${BASH_REMATCH[1]}"
    start_line="${BASH_REMATCH[2]}"
    end_line="${BASH_REMATCH[3]}"
  # Check for single line: #L format (URL fragment style)
  elif [[ "$target" =~ ^(.+)#[Ll]([0-9]+)$ ]]; then
    file_path="${BASH_REMATCH[1]}"
    start_line="${BASH_REMATCH[2]}"
  # Check for single line: :line format
  elif [[ "$target" =~ ^(.+):([0-9]+)$ ]]; then
    file_path="${BASH_REMATCH[1]}"
    start_line="${BASH_REMATCH[2]}"
  else
    file_path="$target"
  fi

  # Handle file:// prefix
  if [[ "$file_path" =~ ^file://([^/]*)(/.*)$ ]]; then
    file_path="${BASH_REMATCH[2]}"
  fi

  echo "$file_path"
  echo "$start_line"
  echo "$end_line"
}

# Check if a tmux session has any attached clients
session_has_clients() {
  local session="$1"
  local clients
  clients=$(tmux list-clients -t "$session" 2>/dev/null)
  [[ -n "$clients" ]]
}

# Open a new Terminal window and attach to the specified tmux session
open_terminal_for_session() {
  local session="$1"
  local system
  system="$(uname -s)"

  case "$system" in
    Darwin)
      # macOS: Use AppleScript to open Terminal
      osascript -e "
        tell application \"Terminal\"
          do script \"tmux attach-session -t '$session'\"
          activate
        end tell
      " >/dev/null 2>&1
      ;;
    Linux)
      # Linux: Try various terminal emulators
      if command -v gnome-terminal >/dev/null 2>&1; then
        gnome-terminal -- tmux attach-session -t "$session" &
      elif command -v kitty >/dev/null 2>&1; then
        kitty tmux attach-session -t "$session" &
      elif command -v alacritty >/dev/null 2>&1; then
        alacritty -e tmux attach-session -t "$session" &
      elif command -v xterm >/dev/null 2>&1; then
        xterm -e "tmux attach-session -t '$session'" &
      elif command -v konsole >/dev/null 2>&1; then
        konsole -e tmux attach-session -t "$session" &
      else
        echo "Warning: No supported terminal emulator found" >&2
        return 1
      fi
      ;;
    *)
      echo "Warning: Unsupported platform for terminal auto-attach: $system" >&2
      return 1
      ;;
  esac
}

# Focus a tmux pane, switching sessions if needed
# Handles cross-session focus by using switch-client when the target
# pane is in a different tmux session than the client's current session.
# Args: pane_id (e.g. %15), window_target (e.g. @3 or session:window)
focus_pane() {
  local pane_id="$1"
  local window_target="$2"

  # Get the session that owns the target pane
  local target_session
  target_session=$(tmux list-panes -a -F "#{pane_id} #{session_name}" \
    | grep "^${pane_id} " | cut -d' ' -f2)

  # Find the user's client and switch it to the target session
  # Priority: focused client > first attached client.
  # Trailing `|| true` so a grep miss (no focused client — common when tmux
  # hasn't seen a focus event recently) doesn't kill the script under
  # pipefail/errexit.
  local client_tty=""
  client_tty=$(tmux list-clients -F "#{client_tty} #{client_flags}" 2>/dev/null \
    | grep "focused" | head -1 | cut -d' ' -f1 || true)
  if [[ -z "$client_tty" ]]; then
    # No focused client, use first attached
    client_tty=$(tmux list-clients -F "#{client_tty}" 2>/dev/null | head -1)
  fi

  if [[ -n "$client_tty" && -n "$target_session" ]]; then
    # Get the client's current session
    local client_session
    client_session=$(tmux list-clients -F "#{client_tty} #{client_session}" 2>/dev/null \
      | grep "^${client_tty} " | cut -d' ' -f2)
    if [[ "$client_session" != "$target_session" ]]; then
      tmux switch-client -c "$client_tty" -t "$target_session" 2>/dev/null || true
    fi
  fi

  tmux select-window -t "$window_target" 2>/dev/null
  tmux select-pane -t "$pane_id" 2>/dev/null

  # Signal VoiceMode that visual focus was just taken (visual conch).
  # Suppresses auto-focus-pane for the hold duration (default 30s).
  mkdir -p ~/.voicemode 2>/dev/null
  echo "${SHOW_HOLD_SECONDS:-30}" > ~/.voicemode/focus-hold
}

# Find an existing show-managed Neovim pane in the current window
# Scans all panes in the current tmux window for nvim-show-pane-* sockets
# Returns: pane ID (e.g. %15) on stdout if found, or returns 1 if none
find_nvim_show_pane() {
  local socket_dir
  socket_dir=$(get_socket_dir)

  # Get all pane IDs in the current window only
  local pane_ids
  pane_ids=$(tmux list-panes -F '#{pane_id}')

  local pane_id
  for pane_id in $pane_ids; do
    local socket="${socket_dir}/nvim-show-pane-${pane_id#%}"
    if [[ -S "$socket" ]]; then
      # Socket file exists, verify Neovim is responsive
      if nvim --server "$socket" --remote-expr "1" >/dev/null 2>&1; then
        echo "$pane_id"
        return 0
      else
        # Stale socket: Neovim crashed or exited, clean up
        rm -f "$socket" 2>/dev/null
      fi
    fi
  done
  return 1
}

# Get or create the show tmux session and window
get_or_create_show_window() {
  local session="$1"
  local window="$2"

  # Check if session exists
  if ! tmux has-session -t "$session" 2>/dev/null; then
    # Create session with target window
    tmux new-session -d -s "$session" -n "$window"
    echo "Created session: $session" >&2
  fi

  # Check if target window exists in session
  if ! tmux list-windows -t "$session" -F "#{window_name}" | grep -q "^${window}$"; then
    tmux new-window -t "$session" -n "$window"
    echo "Created window: $window" >&2
  fi

  # Auto-attach terminal if session has no clients and auto-attach is enabled
  if [[ "$SHOW_AUTO_ATTACH" == "true" ]] && ! session_has_clients "$session"; then
    open_terminal_for_session "$session"
    # Give terminal time to attach
    sleep 0.5
  fi
}

# Find or create editor pane in show window
get_editor_pane() {
  local session="$1"
  local window="$2"
  local pane_id

  # Get the first pane in the target window
  pane_id=$(tmux list-panes -t "${session}:${window}" -F "#{pane_id}" 2>/dev/null | head -1)

  if [[ -z "$pane_id" ]]; then
    echo "Error: Could not find pane in ${session}:${window}" >&2
    return 1
  fi

  echo "$pane_id"
}

# Wait for Neovim socket to become available
# Args: socket_path, max_attempts (default 15), delay_ms (default 200)
# Returns: 0 if socket ready, 1 if timeout
wait_for_nvim_socket() {
  local socket_path="$1"
  local max_attempts="${2:-15}"  # 15 * 0.2s = 3 seconds max
  local delay="${3:-0.2}"
  local attempt=0

  while [[ $attempt -lt $max_attempts ]]; do
    if [[ -S "$socket_path" ]]; then
      # Socket exists, verify it's responding
      if nvim --server "$socket_path" --remote-expr "1" >/dev/null 2>&1; then
        return 0
      fi
    fi
    sleep "$delay"
    ((attempt++))
  done

  return 1
}

# Find or create shell pane in show window
get_shell_pane() {
  local session="$1"
  local window="$2"
  local panes

  # Count panes in target window
  panes=$(tmux list-panes -t "${session}:${window}" -F "#{pane_id}" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$panes" -lt 2 ]]; then
    # Split to create shell pane
    tmux split-window -t "${session}:${window}" -v -p 20
  fi

  # Get the second (bottom) pane
  tmux list-panes -t "${session}:${window}" -F "#{pane_id}" 2>/dev/null | tail -1
}

# Open file in Neovim
handle_file() {
  local target="$1"
  local session="$2"
  local window="$3"
  local explicit_pane="${4:-}"
  local layout="${5:-}"

  # Resolve 'here' sentinel to 'right' for files
  if [[ "$layout" == "here" ]]; then
    layout="right"
  fi

  # Parse file and line number/range
  local parsed
  parsed=$(parse_file_target "$target")
  local file_path
  local start_line
  local end_line
  file_path=$(echo "$parsed" | sed -n '1p')
  start_line=$(echo "$parsed" | sed -n '2p')
  end_line=$(echo "$parsed" | sed -n '3p')

  # Resolve to absolute path
  if [[ ! "$file_path" =~ ^/ ]]; then
    file_path="$(pwd)/$file_path"
  fi
  file_path=$(realpath "$file_path" 2>/dev/null || echo "$file_path")

  # Verify file exists
  if [[ ! -f "$file_path" ]]; then
    echo "Error: File not found: $file_path" >&2
    return 1
  fi

  local pane_id
  local use_split=false
  local display_location

  if is_split_layout "$layout"; then
    # Split mode: check for existing Neovim pane before creating a new split.
    # File shows REUSE existing nvim under any split layout including stacked
    # (SHOW-68). The stacked-skip-reuse guard was originally added (SHOW-54)
    # because stacked was designed for teammate-style accumulation where each
    # spawn wants its own pane — but that's the `cmd:` use case. For file
    # shows, reuse is correct: subsequent `show file.md` calls land in the
    # same nvim. handle_command keeps its own create-new-pane behavior, so
    # cmd-driven teammate accumulation under stacked is unaffected. handle_diff
    # also keeps the stacked-skip-reuse guard to avoid the SHOW-62 hijack.
    use_split=true
    local existing_pane
    if existing_pane=$(find_nvim_show_pane); then
      pane_id="$existing_pane"
      display_location="split (reused)"
    else
      if ! pane_id=$(create_split_pane "$layout"); then
        exit 1
      fi
      display_location="split ($layout)"
    fi
  else
    # Window mode: use separate show window (existing behavior)
    get_or_create_show_window "$session" "$window"
    if [[ -n "$explicit_pane" ]]; then
      pane_id="$explicit_pane"
    else
      pane_id=$(get_editor_pane "$session" "$window")
    fi
    display_location="${session}:${window}"
  fi

  # Socket path in private directory
  local socket_dir
  socket_dir=$(get_socket_dir)
  local socket_path="${socket_dir}/nvim-show-pane-${pane_id#%}"

  if [[ -S "$socket_path" ]]; then
    # Socket exists, wait for it to be responsive (may have just started)
    if wait_for_nvim_socket "$socket_path" 5 0.2; then
      # Neovim running and responsive, open file remotely
      nvim --server "$socket_path" --remote "$file_path" 2>/dev/null

      if [[ -n "$end_line" && "$end_line" =~ ^[0-9]+$ ]]; then
        # Line range: use visual line mode to highlight
        nvim --server "$socket_path" --remote-send ":${start_line}<CR>V${end_line}G" 2>/dev/null
        echo "Opened $file_path highlighting lines $start_line-$end_line in $display_location"
      elif [[ -n "$start_line" && "$start_line" =~ ^[0-9]+$ ]]; then
        # Single line: jump to line
        nvim --server "$socket_path" --remote-send ":${start_line}<CR>" 2>/dev/null
        echo "Opened $file_path at line $start_line in $display_location"
      else
        # No line number
        echo "Opened $file_path in $display_location"
      fi
    else
      echo "Error: Neovim socket exists but not responding: $socket_path" >&2
      return 1
    fi
  else
    # Start neovim in pane.
    # Use printf %q to safely quote socket and file paths — handles spaces,
    # quotes, and other shell-meaningful characters in filenames.
    local nvim_cmd
    printf -v nvim_cmd 'nvim --listen %q %q' "$socket_path" "$file_path"
    tmux send-keys -t "$pane_id" "$nvim_cmd" Enter

    # Wait for Neovim to start and socket to become available
    if wait_for_nvim_socket "$socket_path"; then
      # Socket ready, now jump to line/range if specified
      if [[ -n "$end_line" && "$end_line" =~ ^[0-9]+$ ]]; then
        # Line range: use visual line mode to highlight
        nvim --server "$socket_path" --remote-send ":${start_line}<CR>V${end_line}G" 2>/dev/null
        echo "Opened $file_path highlighting lines $start_line-$end_line in $display_location"
      elif [[ -n "$start_line" && "$start_line" =~ ^[0-9]+$ ]]; then
        # Single line: jump to line
        nvim --server "$socket_path" --remote-send ":${start_line}<CR>" 2>/dev/null
        echo "Opened $file_path at line $start_line in $display_location"
      else
        # No line number
        echo "Opened $file_path in $display_location"
      fi
    else
      # Socket didn't become available, but Neovim might still work
      echo "Started Neovim with $file_path in $display_location (socket startup slow)"
    fi
  fi

  if [[ "$use_split" == true ]]; then
    # Split mode: no zoom (side-by-side is the point), no cross-session focus switch
    # Still write focus-hold for VoiceMode visual conch
    mkdir -p ~/.voicemode 2>/dev/null
    echo "${SHOW_HOLD_SECONDS:-30}" > ~/.voicemode/focus-hold
  else
    # Window mode: focus and zoom as before
    if [[ "$SHOW_FOCUS" == "true" ]]; then
      focus_pane "$pane_id" "${session}:${window}"
    fi

    if [[ "$SHOW_ZOOM" == "true" ]]; then
      # Only zoom if not already zoomed
      local is_zoomed
      is_zoomed=$(tmux display-message -t "$pane_id" -p '#{window_zoomed_flag}' 2>/dev/null)
      if [[ "$is_zoomed" != "1" ]]; then
        tmux resize-pane -t "$pane_id" -Z 2>/dev/null
      fi
    fi
  fi
}

# Open URL in browser
handle_url() {
  local url="$1"

  # Ensure URL has scheme
  if [[ ! "$url" =~ ^https?:// ]]; then
    url="https://$url"
  fi

  # Use configured browser if set
  if [[ -n "$SHOW_BROWSER" ]]; then
    case "$(uname -s)" in
      Darwin)
        open -a "$SHOW_BROWSER" "$url" 2>/dev/null || {
          echo "Error: Could not open with browser: $SHOW_BROWSER" >&2
          return 1
        }
        ;;
      Linux)
        "$SHOW_BROWSER" "$url" 2>/dev/null &
        ;;
    esac
    echo "Opened $url in $SHOW_BROWSER"
    return 0
  fi

  # Auto-detect browser based on OS
  case "$(uname -s)" in
    Darwin)
      # macOS: Try Firefox first, fall back to default browser
      if command -v firefox >/dev/null 2>&1 || [[ -d "/Applications/Firefox.app" ]]; then
        open -a Firefox "$url" 2>/dev/null || open "$url"
      else
        open "$url"
      fi
      ;;
    Linux)
      # Linux: Use xdg-open or firefox
      if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url" 2>/dev/null &
      elif command -v firefox >/dev/null 2>&1; then
        firefox "$url" 2>/dev/null &
      else
        echo "Error: No browser found" >&2
        return 1
      fi
      ;;
    *)
      echo "Error: Unsupported platform: $(uname -s)" >&2
      return 1
      ;;
  esac

  echo "Opened $url in browser"
}

# Minimal JSON string escaper (no jq dependency). Escapes the characters
# JSON requires: backslash, double-quote, and the common control chars.
json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  printf '%s' "$s"
}

# Emit the cmd: handle. SHOW-92: humans get the unchanged line plus an
# additive `[pane %NN]` suffix; agents pass --format json for a one-line
# machine-readable handle (pane, session, window name, created, status).
emit_command_handle() {
  local pane_id="$1" command="$2" display_location="$3" layout="$4" created="$5"

  # Liveness (best-effort). A dead pane is only observable if remain-on-exit
  # is set; otherwise tmux removes it and we report status=unknown.
  local status="alive"
  if ! tmux display-message -p -t "$pane_id" '' >/dev/null 2>&1; then
    status="unknown"
  elif [[ "$(tmux display-message -p -t "$pane_id" '#{pane_dead}' 2>/dev/null)" == "1" ]]; then
    local code
    code=$(tmux display-message -p -t "$pane_id" '#{pane_dead_status}' 2>/dev/null)
    status="exited:${code:-unknown}"
  fi

  if [[ "$SHOW_FORMAT" == "json" ]]; then
    local s_name w_name w_idx p_idx
    IFS='|' read -r s_name w_name w_idx p_idx < <(
      tmux display-message -p -t "$pane_id" \
        '#{session_name}|#{window_name}|#{window_index}|#{pane_index}' 2>/dev/null)
    printf '{"pane":"%s","session":"%s","window":"%s","window_index":%s,"pane_index":%s,"created":%s,"layout":"%s","status":"%s","cmd":"%s"}\n' \
      "$(json_escape "$pane_id")" \
      "$(json_escape "$s_name")" \
      "$(json_escape "$w_name")" \
      "${w_idx:-null}" \
      "${p_idx:-null}" \
      "$created" \
      "$(json_escape "$layout")" \
      "$(json_escape "$status")" \
      "$(json_escape "$command")"
  else
    # Option A: unchanged human line + additive pane handle.
    echo "Executed: $command in $display_location [pane $pane_id]"
  fi
}

# Run command in shell pane
handle_command() {
  local command="$1"
  local session="$2"
  local window="$3"
  local explicit_pane="${4:-}"
  local layout="${5:-}"

  # Resolve 'here' sentinel to 'below' for commands
  if [[ "$layout" == "here" ]]; then
    layout="below"
  fi

  # Remove cmd: or command: prefix
  command="${command#cmd:}"
  command="${command#command:}"

  local pane_id
  local use_split=false
  local display_location

  # Snapshot existing panes so we can report created=true|false for the
  # resolved pane (SHOW-92). tmux never reuses pane IDs, so "not in the
  # before-set" is a reliable new-pane signal regardless of split/window path.
  local panes_before
  panes_before=$(tmux list-panes -a -F '#{pane_id}' 2>/dev/null)

  if is_split_layout "$layout"; then
    # Split mode: create pane in current window
    use_split=true
    if ! pane_id=$(create_split_pane "$layout"); then
      exit 1
    fi
    display_location="split ($layout)"
  else
    # Window mode: use separate show window (existing behavior)
    if [[ -n "$explicit_pane" ]]; then
      pane_id="$explicit_pane"
    else
      get_or_create_show_window "$session" "$window"
      pane_id=$(get_shell_pane "$session" "$window")
    fi
    display_location="${session}:${window}"
  fi

  # created=true when the resolved pane did not exist before this call.
  local created=false
  if ! grep -qxF "$pane_id" <<<"$panes_before"; then
    created=true
  fi

  # Send command to pane
  tmux send-keys -t "$pane_id" "$command" Enter

  if [[ "$use_split" == true ]]; then
    # Split mode: no cross-session focus switch (already in current window)
    # Still write focus-hold for VoiceMode visual conch
    mkdir -p ~/.voicemode 2>/dev/null
    echo "${SHOW_HOLD_SECONDS:-30}" > ~/.voicemode/focus-hold
  else
    # Window mode: focus as before
    if [[ "$SHOW_FOCUS" == "true" ]]; then
      focus_pane "$pane_id" "${session}:${window}"
    fi
  fi

  emit_command_handle "$pane_id" "$command" "$display_location" "$layout" "$created"
}

# Focus a tmux pane (supports cross-session switching)
handle_pane() {
  local pane_spec="$1"
  local layout="${2:-}"  # Layout mode (unused until SHOW-21)

  # Remove pane: prefix
  pane_spec="${pane_spec#pane:}"

  # Resolve "self" to the current pane
  if [[ "$pane_spec" == "self" ]]; then
    if [[ -n "${TMUX_PANE:-}" ]]; then
      pane_spec="$TMUX_PANE"
    else
      echo "Error: pane:self requires running inside tmux (TMUX_PANE not set)" >&2
      return 1
    fi
  fi

  # Add % prefix if needed
  if [[ ! "$pane_spec" =~ ^% ]]; then
    pane_spec="%$pane_spec"
  fi

  # Verify pane exists
  if ! tmux list-panes -a -F "#{pane_id}" | grep -q "^${pane_spec}$"; then
    echo "Error: Pane not found: $pane_spec" >&2
    return 1
  fi

  # Get window for pane
  local window_id
  window_id=$(tmux list-panes -a -F "#{pane_id} #{window_id}" | grep "^${pane_spec} " | cut -d' ' -f2)

  # Focus pane with cross-session support
  focus_pane "$pane_spec" "$window_id"

  echo "Focused pane $pane_spec"
}

# Open git diff in Neovim DiffView
# Requires sindrets/diffview.nvim plugin in Neovim config
handle_diff() {
  local target="$1"
  local session="$2"
  local window="$3"
  local explicit_pane="${4:-}"
  local layout="${5:-}"

  # Resolve 'here' sentinel to 'right' for diff (uses Neovim like files)
  if [[ "$layout" == "here" ]]; then
    layout="right"
  fi

  # Strip diff: prefix if present
  local diff_args=""
  if [[ "$target" == "diff" ]]; then
    diff_args=""
  elif [[ "$target" =~ ^diff:(.*)$ ]]; then
    diff_args="${BASH_REMATCH[1]}"
  fi

  # Verify we're in a git repo
  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: Not in a git repository" >&2
    return 1
  }

  local pane_id
  local use_split=false
  local display_location

  if is_split_layout "$layout"; then
    # Split mode: check for existing Neovim pane before creating a new split
    # Stacked always creates a new pane — never reuse an existing Neovim instance
    use_split=true
    local existing_pane
    if [[ "$layout" != "stacked" ]] && existing_pane=$(find_nvim_show_pane); then
      pane_id="$existing_pane"
      display_location="split (reused)"
    else
      if ! pane_id=$(create_split_pane "$layout"); then
        exit 1
      fi
      display_location="split ($layout)"
    fi
  else
    # Window mode: use separate show window (existing behavior)
    get_or_create_show_window "$session" "$window"
    if [[ -n "$explicit_pane" ]]; then
      pane_id="$explicit_pane"
    else
      pane_id=$(get_editor_pane "$session" "$window")
    fi
    display_location="${session}:${window}"
  fi

  # Socket path in private directory
  local socket_dir
  socket_dir=$(get_socket_dir)
  local socket_path="${socket_dir}/nvim-show-pane-${pane_id#%}"

  # Build the DiffviewOpen command
  local nvim_diffview_cmd="DiffviewOpen ${diff_args}"

  if [[ -S "$socket_path" ]]; then
    # Neovim already running — send DiffviewOpen command
    if wait_for_nvim_socket "$socket_path" 5 0.2; then
      # Close any dashboard/special buffer, cd to git root, then open DiffView
      nvim --server "$socket_path" --remote-send "<Esc>:silent! Snacks.dashboard.close()<CR>:cd ${git_root}<CR>:${nvim_diffview_cmd}<CR>" 2>/dev/null
    else
      echo "Error: Neovim socket exists but not responding: $socket_path" >&2
      return 1
    fi
  else
    # Start Neovim in the git root with DiffView as startup command.
    # Using +command avoids race with dashboard and plugin lazy-loading.
    # Use printf %q to safely quote git_root and socket_path; the +command
    # form needs spaces escaped so the whole +DiffviewOpen ... arg stays one token.
    local escaped_cmd="${nvim_diffview_cmd// /\\ }"
    local nvim_cmd
    printf -v nvim_cmd 'cd %q && nvim --listen %q +%s' \
      "$git_root" "$socket_path" "$escaped_cmd"
    tmux send-keys -t "$pane_id" "$nvim_cmd" Enter

    if ! wait_for_nvim_socket "$socket_path"; then
      echo "Started Neovim in $display_location (socket startup slow, DiffView may not have opened)" >&2
    fi
  fi

  # Build descriptive message
  local description
  if [[ -z "$diff_args" ]]; then
    description="unstaged changes"
  else
    description="$diff_args"
  fi
  echo "Opened DiffView (${description}) in $display_location"

  if [[ "$use_split" == true ]]; then
    # Split mode: no zoom (side-by-side is the point), no cross-session focus switch
    # Still write focus-hold for VoiceMode visual conch
    mkdir -p ~/.voicemode 2>/dev/null
    echo "${SHOW_HOLD_SECONDS:-30}" > ~/.voicemode/focus-hold
  else
    # Window mode: focus and zoom as before
    if [[ "$SHOW_FOCUS" == "true" ]]; then
      focus_pane "$pane_id" "${session}:${window}"
    fi

    if [[ "$SHOW_ZOOM" == "true" ]]; then
      local is_zoomed
      is_zoomed=$(tmux display-message -t "$pane_id" -p '#{window_zoomed_flag}' 2>/dev/null)
      if [[ "$is_zoomed" != "1" ]]; then
        tmux resize-pane -t "$pane_id" -Z 2>/dev/null
      fi
    fi
  fi
}

# Validate layout value
# Accepts: right, below, left, above, window, stacked, here, empty string
# Returns: 0 if valid, 1 if invalid (with error message to stderr)
validate_layout() {
  local layout="$1"
  case "$layout" in
    right|below|left|above|window|stacked|here|"") return 0 ;;
    *)
      echo "Error: Invalid layout: $layout" >&2
      echo "Valid values: right, below, left, above, window, stacked" >&2
      return 1
      ;;
  esac
}

# Check if layout is a directional split (not window mode)
# Returns: 0 if layout is right/below/left/above/stacked, 1 otherwise
is_split_layout() {
  local layout="$1"
  case "$layout" in
    right|below|left|above|stacked) return 0 ;;
    *) return 1 ;;
  esac
}

# Re-apply a tmux layout to the panes already in a window.
# Only rearranges existing panes -- never creates or closes a pane.
# Args: window_id, leader_pane, layout
#
# Layout -> tmux arrangement mapping (leader-relative):
#   stacked / right / left  -> main-vertical, leader pinned to ~30% width
#   below / above           -> main-horizontal, leader pinned to ~70% height
#   window / here / other    -> unsupported (clear message, no destructive action)
#
# Returns: 0 on a successful rearrange, 1 for an unsupported layout.
restack_layout() {
  local window_id="$1"
  local leader_pane="$2"
  local layout="$3"

  case "$layout" in
    stacked|right|left)
      # main-vertical: leader is a narrow ~30%-width column, content fills
      # the rest. (stacked's create-time algorithm differs, but the redraw
      # target is the same arrangement.)
      tmux select-layout -t "$window_id" main-vertical 2>/dev/null || true
      tmux resize-pane -t "$leader_pane" -x 30% 2>/dev/null || true
      ;;
    below|above)
      # main-horizontal: content stacked below/above the leader, with the
      # leader keeping the larger ~70% height (mirrors the create-time split).
      tmux select-layout -t "$window_id" main-horizontal 2>/dev/null || true
      tmux resize-pane -t "$leader_pane" -y 70% 2>/dev/null || true
      ;;
    *)
      # window / here / anything else: no sensible single-window rearrangement
      # of existing panes. Do nothing destructive -- never close or move panes.
      echo "Error: --restack does not support layout '$layout'" >&2
      echo "Supported: stacked, right, left, below, above" >&2
      return 1
      ;;
  esac
}

# Handle `show-me --restack [layout]`: re-apply a layout to the panes already
# in the current window, then exit. Creates nothing and shows nothing -- no
# target is required.
#
# Layout precedence: explicit argument > SHOW_LAYOUT (env or --layout) >
# stacked default. The resolved layout is validated against the same value
# set as --layout. Must run inside tmux; exits non-zero with an actionable
# message otherwise, mirroring the stacked-layout error in create_stacked_pane().
#
# Args: layout_arg (may be empty)
do_restack() {
  local layout="$1"

  # Resolve layout: explicit arg > SHOW_LAYOUT > stacked default
  if [[ -z "$layout" ]]; then
    layout="$SHOW_LAYOUT"
  fi
  if [[ -z "$layout" ]]; then
    layout="stacked"
  fi

  # Validate against the same value set as --layout (before touching tmux)
  validate_layout "$layout" || return 1

  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: --restack requires running inside tmux" >&2
    return 1
  fi

  local leader_pane="${TMUX_PANE:-}"
  if [[ -z "$leader_pane" ]]; then
    echo "Error: TMUX_PANE not set; cannot identify leader pane for --restack" >&2
    return 1
  fi

  # Resolve the leader's window via the leader pane id (see create_stacked_pane
  # for why we anchor to the pane rather than the active client).
  local window_id
  window_id=$(tmux display-message -p -t "$leader_pane" '#{window_id}')

  restack_layout "$window_id" "$leader_pane" "$layout"
}

# Create a stacked pane following the tmux teammate-layout algorithm
# Each call adds a new pane to the right-hand stack; leader stays on the left.
# First call: split leader horizontally (leader 30%, content 70%).
# Subsequent calls: split the middle content pane (alternating v/h), then rebalance.
# Must be run inside tmux; exits non-zero with a clear error otherwise.
# Returns: new pane ID (e.g. %15) on stdout
create_stacked_pane() {
  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: --layout stacked requires running inside tmux" >&2
    return 1
  fi

  local leader_pane="${TMUX_PANE:-}"
  if [[ -z "$leader_pane" ]]; then
    echo "Error: TMUX_PANE not set; cannot identify leader pane for stacked layout" >&2
    return 1
  fi

  # Resolve the leader's window via the leader pane id, not the active client.
  # `display-message -p '#{window_id}'` (no -t) returns the focused client's
  # window, which can drift if the user has clicked into a different window
  # between show calls. Anchor to the leader pane to keep splits stable.
  local window_id
  window_id=$(tmux display-message -p -t "$leader_pane" '#{window_id}')

  # Content panes: all panes in the current window except the leader
  local teammates
  teammates=$(tmux list-panes -t "$window_id" -F '#{pane_id}' | grep -v "^${leader_pane}$" || true)
  local teammate_count=0
  [[ -n "$teammates" ]] && teammate_count=$(echo "$teammates" | wc -l | tr -d ' ')

  local new_pane

  if [[ "$teammate_count" -eq 0 ]]; then
    # First content pane: split leader horizontally, content pane gets 70%
    new_pane=$(tmux split-window -t "$leader_pane" -h -l 70% -P -F '#{pane_id}') || {
      echo "Warning: Failed to create stacked pane (window may be too small)" >&2
      return 1
    }
  else
    # Subsequent panes: split the middle content pane, alternating vertical/horizontal
    local mid=$(( (teammate_count - 1) / 2 ))
    local target
    target=$(echo "$teammates" | sed -n "$((mid + 1))p")

    local split_dir
    if (( teammate_count % 2 == 1 )); then
      split_dir="-v"
    else
      split_dir="-h"
    fi

    # shellcheck disable=SC2086
    new_pane=$(tmux split-window -t "$target" $split_dir -P -F '#{pane_id}') || {
      echo "Warning: Failed to create stacked pane (window may be too small)" >&2
      return 1
    }

    # Rebalance: re-apply the stacked layout to the panes we just changed
    restack_layout "$window_id" "$leader_pane" stacked
  fi

  echo "$new_pane"
}

# Create a tmux split pane in the specified direction
# Args: direction (right, below, left, above, stacked)
# Returns: new pane ID (e.g. %15) on stdout
create_split_pane() {
  local direction="$1"

  # Stacked layout uses its own algorithm
  if [[ "$direction" == "stacked" ]]; then
    create_stacked_pane
    return
  fi

  local flags=""

  # Direction-aware default sizes: 70% for side splits (files), 30% for top/bottom (commands)
  local size="${SHOW_SPLIT_SIZE:-}"
  case "$direction" in
    right) size="${size:-70}"; flags="-h -p $size" ;;
    below) size="${size:-30}"; flags="-fv -p $size" ;;
    left)  size="${size:-70}"; flags="-hb -p $size" ;;
    above) size="${size:-30}"; flags="-fvb -p $size" ;;
    *)
      echo "Error: Invalid split direction: $direction" >&2
      return 1
      ;;
  esac

  # Split relative to the agent's pane (not the user's active pane)
  local target_pane="${TMUX_PANE:-}"
  # shellcheck disable=SC2086
  tmux split-window ${target_pane:+-t "$target_pane"} $flags -P -F '#{pane_id}'
}

# Detect target type and dispatch to handler
detect_and_handle() {
  local target="$1"
  local session="$2"
  local window="$3"
  local pane="${4:-}"
  local layout="${5:-}"

  # URL (http:// or https://)
  if [[ "$target" =~ ^https?:// ]]; then
    handle_url "$target"
    return
  fi

  # Git diff (diff or diff:ref)
  if [[ "$target" == "diff" || "$target" =~ ^diff: ]]; then
    handle_diff "$target" "$session" "$window" "$pane" "$layout"
    return
  fi

  # Command (cmd: or command: prefix)
  if [[ "$target" =~ ^(cmd|command): ]]; then
    handle_command "$target" "$session" "$window" "$pane" "$layout"
    return
  fi

  # Pane focus (pane: prefix)
  if [[ "$target" =~ ^pane: ]]; then
    handle_pane "$target" "$layout"
    return
  fi

  # File URL (file://)
  if [[ "$target" =~ ^file:// ]]; then
    handle_file "$target" "$session" "$window" "$pane" "$layout"
    return
  fi

  # Explicit path prefix (absolute, relative, or home) -- always a file
  if [[ "$target" =~ ^(/|\./|\.\./|~) ]]; then
    handle_file "$target" "$session" "$window" "$pane" "$layout"
    return
  fi

  # Existing local file -- always a file. This catches the common case of
  # `show README.md` from a project directory: README.md exists, so it's
  # handled as a file rather than the .md TLD.
  if [[ -e "$target" ]]; then
    handle_file "$target" "$session" "$window" "$pane" "$layout"
    return
  fi

  # Common filename extensions that ALSO happen to be valid TLDs.
  # Without this guard, `show README.md` in a directory without that file
  # would resolve to https://README.md/ -- and typo-squatters on the .md
  # TLD have been known to redirect such hits to junk/affiliate sites.
  # Bare-domain URLs ending in these extensions are still reachable via
  # `show https://example.md/` or `show example.md/path`.
  if [[ "$target" =~ \.(md|js|ts|tsx|jsx|py|rb|sh|go|rs|css|html|htm|json|toml|yml|yaml|xml|sql|conf|cfg|ini|log|txt|nix|lock|env|gitignore)$ ]]; then
    handle_file "$target" "$session" "$window" "$pane" "$layout"
    return
  fi

  # Domain name (contains dot, no path separator at start)
  if [[ "$target" =~ ^[a-zA-Z0-9]([a-zA-Z0-9-]*\.)+[a-zA-Z]{2,} ]]; then
    handle_url "$target"
    return
  fi

  # Default: treat as file
  handle_file "$target" "$session" "$window" "$pane" "$layout"
}

main() {
  # Check tmux is available
  if ! command -v tmux >/dev/null 2>&1; then
    cat >&2 <<EOF
tmux is required for show-me command. Install with:
  macOS:         brew install tmux
  Ubuntu/Debian: sudo apt install tmux
  Fedora:        sudo dnf install tmux
EOF
    exit 1
  fi

  local session=""
  local window=""
  local pane=""
  local target=""
  local hold_seconds=""
  local restack_mode=false
  local restack_layout_arg=""

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -V|--version)
        echo "show-me version $VERSION"
        exit 0
        ;;
      -s|--session)
        session="$2"
        shift 2
        ;;
      -w|--window)
        window="$2"
        shift 2
        ;;
      -p|--pane)
        pane="$2"
        shift 2
        ;;
      --no-focus)
        SHOW_FOCUS="false"
        shift
        ;;
      --no-zoom)
        SHOW_ZOOM="false"
        shift
        ;;
      --no-attach)
        SHOW_AUTO_ATTACH="false"
        shift
        ;;
      --hold)
        hold_seconds="$2"
        shift 2
        ;;
      --layout)
        SHOW_LAYOUT="$2"
        shift 2
        ;;
      --format)
        SHOW_FORMAT="$2"
        shift 2
        ;;
      --here)
        SHOW_LAYOUT="here"
        shift
        ;;
      --restack)
        restack_mode=true
        # Optional layout argument: consume the next token only if it is
        # present and not another flag (e.g. `show-me --restack below`).
        if [[ -n "${2:-}" && "$2" != -* ]]; then
          restack_layout_arg="$2"
          shift 2
        else
          shift
        fi
        ;;
      -*)
        echo "Unknown option: $1" >&2
        exit 1
        ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        else
          echo "Error: Multiple targets specified" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  # --restack: re-apply a layout to existing panes, then exit. No target,
  # creates nothing, shows nothing -- handled before the target requirement.
  if [[ "$restack_mode" == true ]]; then
    do_restack "$restack_layout_arg" && exit 0
    exit 1
  fi

  if [[ -z "$target" ]]; then
    echo "Error: No target specified" >&2
    echo "Run 'show-me --help' for usage" >&2
    exit 1
  fi

  # Default layout: stacked (SHOW-86). Empty SHOW_LAYOUT (no env var, no
  # --layout flag) resolves to 'stacked'. Explicit --here keeps its sentinel
  # value so handle_* functions can still pick content-type direction.
  # Escape hatch: SHOW_LAYOUT=window (or --layout window) restores the
  # pre-2.4 separate-window behavior.
  if [[ -z "$SHOW_LAYOUT" ]]; then
    SHOW_LAYOUT="stacked"
  fi

  # Validate layout value
  validate_layout "$SHOW_LAYOUT" || exit 1

  # Validate output format (SHOW-92)
  case "$SHOW_FORMAT" in
    human|json) ;;
    *)
      echo "Error: Invalid format: $SHOW_FORMAT (expected: human, json)" >&2
      exit 1
      ;;
  esac

  # Set hold duration: CLI --hold > env var > default 30
  if [[ -n "$hold_seconds" ]]; then
    SHOW_HOLD_SECONDS="$hold_seconds"
  fi
  export SHOW_HOLD_SECONDS="${SHOW_HOLD_SECONDS:-30}"

  # Resolve session: CLI > env var > auto-detect
  if [[ -z "$session" ]]; then
    session=$(get_target_session "$SHOW_SESSION")
  fi

  # Resolve window: CLI > env var > default
  if [[ -z "$window" ]]; then
    window="$SHOW_WINDOW"
  fi

  detect_and_handle "$target" "$session" "$window" "$pane" "$SHOW_LAYOUT"
}

# Run if not sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
