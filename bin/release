#!/usr/bin/env bash
# release - Atomic version bump + release for show-me
#
# Bumps version in BOTH bin/show-me (VERSION="X.Y.Z") and .claude-plugin/plugin.json
# (.version) in a single commit, then tags and pushes. Prevents the drift bug
# fixed in SHOW-64 from reoccurring.
#
# Usage:
#   bin/release                # interactive: shows current, suggests next-patch as default
#   bin/release patch          # X.Y.Z -> X.Y.(Z+1)
#   bin/release minor          # X.Y.Z -> X.(Y+1).0
#   bin/release major          # X.Y.Z -> (X+1).0.0
#   bin/release 2.4.0          # set explicit version
#   bin/release --dry-run 2.4.0  # update files, skip git ops (for testing)
#   bin/release --allow-empty patch  # release even if [Unreleased] is empty
#   bin/release --allow-patch patch  # skip the minor-bump nudge (patch despite ### Added)
#
# Contract: do NOT edit VERSION in bin/show-me or .version in plugin.json by hand.
# This script is the single source of truth for bumping both.

set -o nounset -o pipefail -o errexit

DRY_RUN=0
ALLOW_EMPTY=0
ALLOW_PATCH=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)     DRY_RUN=1; shift ;;
    --allow-empty) ALLOW_EMPTY=1; shift ;;
    --allow-patch) ALLOW_PATCH=1; shift ;;
    -h|--help)
      sed -n '1,18p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -*)
      echo "Unknown flag: $1" >&2
      exit 2
      ;;
    *) break ;;
  esac
done

ARG="${1:-}"

# Resolve repo root (parent of bin/)
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"
SHOW_BIN="$REPO_ROOT/bin/show-me"
CHANGELOG="$REPO_ROOT/CHANGELOG.md"

# SHOW-125 made bin/show-me a symlink to the canonical script under skills/.
# Resolve it to the real file so the VERSION bump below lands in -- and stages --
# the canonical script. A plain `mv tmp bin/show-me` would replace the symlink
# with a regular-file copy, bumping a dead file while the real script stayed
# stale (and quietly breaking the single-source layout).
if [[ -L "$SHOW_BIN" ]]; then
  _link="$(readlink "$SHOW_BIN")"
  if [[ "$_link" = /* ]]; then
    SHOW_BIN="$_link"
  else
    SHOW_BIN="$(cd "$(dirname "$SHOW_BIN")/$(dirname "$_link")" && pwd)/$(basename "$_link")"
  fi
fi

for f in "$PLUGIN_JSON" "$SHOW_BIN"; do
  [[ -f "$f" ]] || { echo "Error: missing $f" >&2; exit 1; }
done

command -v jq >/dev/null 2>&1 || { echo "Error: jq required" >&2; exit 1; }

# Refuse to operate on a dirty working tree (skip in dry-run for testability)
if [[ $DRY_RUN -eq 0 ]]; then
  if ! git -C "$REPO_ROOT" diff --quiet || ! git -C "$REPO_ROOT" diff --cached --quiet; then
    echo "Error: uncommitted changes. Commit or stash first." >&2
    git -C "$REPO_ROOT" status --short >&2
    exit 1
  fi
fi

CURRENT="$(jq -r .version "$PLUGIN_JSON")"

bump() {
  local cur="$1" kind="$2"
  IFS=. read -r maj min pat <<< "$cur"
  case "$kind" in
    patch) echo "$maj.$min.$((pat + 1))" ;;
    minor) echo "$maj.$((min + 1)).0" ;;
    major) echo "$((maj + 1)).0.0" ;;
    *) echo "$kind" ;;  # explicit version
  esac
}

# --- Layer 1: git check -- any commits since last release tag? ---
LAST_TAG=$(git -C "$REPO_ROOT" describe --tags --abbrev=0 --match='v*.*.*' 2>/dev/null || true)
COMMITS_SINCE=0
if [[ -n "$LAST_TAG" ]]; then
  COMMITS_SINCE=$(git -C "$REPO_ROOT" rev-list --count "${LAST_TAG}..HEAD" 2>/dev/null || echo 0)
  if [[ "$COMMITS_SINCE" -eq 0 && $ALLOW_EMPTY -eq 0 ]]; then
    echo "Error: no commits since $LAST_TAG -- nothing to release." >&2
    echo "       (Use --allow-empty to override.)" >&2
    exit 1
  fi
fi

# --- Layer 2: CHANGELOG check -- does [Unreleased] have entries? ---
UNRELEASED_BODY=""
if [[ -f "$CHANGELOG" ]] && grep -q "^## \[Unreleased\]" "$CHANGELOG"; then
  UNRELEASED_BODY=$(awk '
    /^## \[Unreleased\]/ { in_section = 1; next }
    in_section && /^## \[/ { exit }
    in_section { print }
  ' "$CHANGELOG" | grep -E '^[^[:space:]]' | grep -v '^<!--' || true)
fi

if [[ -z "$UNRELEASED_BODY" && $ALLOW_EMPTY -eq 0 ]]; then
  if [[ "$COMMITS_SINCE" -gt 0 && -n "$LAST_TAG" ]]; then
    # Commits exist but no CHANGELOG entries -- show titles + prompt
    echo ""
    echo "Warning: $COMMITS_SINCE commit(s) since $LAST_TAG, but [Unreleased] in CHANGELOG.md is empty."
    echo ""
    echo "Commits since $LAST_TAG:"
    git -C "$REPO_ROOT" log --oneline "${LAST_TAG}..HEAD" | sed 's/^/  /'
    echo ""
    printf "Release anyway without CHANGELOG entries? [y/N]: "
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
  else
    echo "Error: [Unreleased] section in CHANGELOG.md is empty." >&2
    echo "       Add entries describing what's shipping, OR pass --allow-empty if intentional." >&2
    exit 1
  fi
fi

# Interactive mode if no version arg given. Mirrors claude-plugin-release convention.
if [[ -z "$ARG" ]]; then
  next_patch="$(bump "$CURRENT" patch)"
  next_minor="$(bump "$CURRENT" minor)"
  next_major="$(bump "$CURRENT" major)"

  echo ""
  echo "Current version: $CURRENT"
  echo ""
  echo "Suggested versions:"
  echo "  [enter] patch: $next_patch  (bug fixes, small changes)"
  echo "  [m]     minor: $next_minor  (new features)"
  echo "  [M]     major: $next_major  (breaking changes)"
  echo ""
  printf "New version [%s]: " "$next_patch"
  read -r choice

  case "$choice" in
    "")  ARG="patch" ;;
    m|minor) ARG="minor" ;;
    M|major) ARG="major" ;;
    *)   ARG="$choice" ;;  # explicit version string
  esac
fi

NEW="$(bump "$CURRENT" "$ARG")"

# Validate semver shape
if ! [[ "$NEW" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "Error: '$NEW' is not a valid X.Y.Z version" >&2
  exit 1
fi

# Minor-bump nudge: if [Unreleased] ships features (an '### Added' section) but
# this is a PATCH bump, stop and confirm -- SemVer wants a minor. v3.0.3 went out
# as a patch despite shipping features (a new env var + alias); this catches the
# next one. Bypass with --allow-patch, or do the right thing with BUMP=minor.
IFS=. read -r _cmaj _cmin _cpat <<< "$CURRENT"
IFS=. read -r _nmaj _nmin _npat <<< "$NEW"
if [[ $ALLOW_PATCH -eq 0 && "$_nmaj" == "$_cmaj" && "$_nmin" == "$_cmin" && "$_npat" -gt "$_cpat" ]]; then
  has_added=""
  [[ -f "$CHANGELOG" ]] && has_added=$(awk '
    /^## \[Unreleased\]/ { in_u = 1; next }
    in_u && /^## \[/     { exit }
    in_u && /^### Added/  { print; exit }
  ' "$CHANGELOG")
  if [[ -n "$has_added" ]]; then
    suggested="$(bump "$CURRENT" minor)"
    echo ""
    echo "Warning: [Unreleased] has an '### Added' section (new features), but this is"
    echo "         a PATCH bump ($CURRENT -> $NEW). SemVer suggests a minor bump"
    echo "         ($CURRENT -> $suggested)."
    if [[ $DRY_RUN -eq 1 ]]; then
      echo "         (--dry-run: not prompting; pass --allow-patch to silence.)"
    else
      printf "Cut a PATCH release anyway? [y/N]: "
      read -r ans
      [[ "$ans" =~ ^[Yy]$ ]] || {
        echo "Aborted. Re-run with BUMP=minor (make release BUMP=minor)," >&2
        echo "        or --allow-patch to force a patch despite the Added section." >&2
        exit 1
      }
    fi
  fi
fi

echo "Bumping $CURRENT -> $NEW"

# 1. plugin.json -- jq to temp file, then mv (atomic on same fs)
tmp="$(mktemp)"
jq --arg v "$NEW" '.version = $v' "$PLUGIN_JSON" > "$tmp"
mv "$tmp" "$PLUGIN_JSON"
echo "  updated $PLUGIN_JSON"

# 2. bin/show-me -- portable sed (BSD on macOS, GNU on linux, also handles
# homebrew gnu-sed shadowing /usr/bin/sed on macOS). Write to temp file then
# mv -- avoids the -i '' vs -i incantation entirely.
tmp_show="$(mktemp)"
sed -E "s/^VERSION=\"[^\"]*\"/VERSION=\"$NEW\"/" "$SHOW_BIN" > "$tmp_show"
# Sanity: the substitution must have actually fired
if ! grep -q "^VERSION=\"$NEW\"" "$tmp_show"; then
  rm -f "$tmp_show"
  echo "Error: failed to update VERSION line in $SHOW_BIN" >&2
  exit 1
fi
# Preserve executable bit
chmod --reference="$SHOW_BIN" "$tmp_show" 2>/dev/null || chmod +x "$tmp_show"
mv "$tmp_show" "$SHOW_BIN"
echo "  updated $SHOW_BIN"

# 3. CHANGELOG.md -- promote [Unreleased] to new version section (if present)
CHANGELOG_UPDATED=0
if [[ -f "$CHANGELOG" ]] && grep -q "^## \[Unreleased\]" "$CHANGELOG"; then
  date_str="$(date +%Y-%m-%d)"
  tmp_cl="$(mktemp)"
  awk -v ver="$NEW" -v d="$date_str" '
    /^## \[Unreleased\]/ && !done {
      print "## [Unreleased]"
      print ""
      print "## [" ver "] - " d
      done = 1
      next
    }
    { print }
  ' "$CHANGELOG" > "$tmp_cl"
  mv "$tmp_cl" "$CHANGELOG"
  echo "  updated $CHANGELOG"
  CHANGELOG_UPDATED=1
fi

# Run tests so the drift check (and rest of suite) gates the release
echo ""
echo "Running tests..."
( cd "$REPO_ROOT" && bash tests/test_show.sh )

if [[ $DRY_RUN -eq 1 ]]; then
  echo ""
  echo "[dry-run] Skipping git commit/tag/push. File changes left in working tree."
  exit 0
fi

# Git ops -- atomic commit with both files (and CHANGELOG if updated)
git -C "$REPO_ROOT" add "$PLUGIN_JSON" "$SHOW_BIN"
[[ $CHANGELOG_UPDATED -eq 1 ]] && git -C "$REPO_ROOT" add "$CHANGELOG"
git -C "$REPO_ROOT" commit -m "Release v$NEW"
git -C "$REPO_ROOT" tag -a "v$NEW" -m "Release v$NEW"

echo ""
echo "Pushing..."
git -C "$REPO_ROOT" push
git -C "$REPO_ROOT" push --tags

# Mirror to the public GitHub remote if present. origin is the ms2 self-host;
# github is the public mirror, which `git push` (upstream = origin) never touches.
# Non-fatal: the release is already committed, tagged, and live on origin by now,
# so a mirror hiccup warns rather than failing the release.
if git -C "$REPO_ROOT" remote | grep -qx github; then
  echo ""
  echo "Mirroring to github..."
  branch="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
  if git -C "$REPO_ROOT" push github "$branch" && git -C "$REPO_ROOT" push github --tags; then
    echo "  mirrored to github"
  else
    echo "  WARNING: github mirror push failed -- release is live on origin;" >&2
    echo "           run: git push github $branch --tags" >&2
  fi
fi

echo ""
echo "Released v$NEW"
