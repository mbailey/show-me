#!/usr/bin/env bash
set -o nounset -o pipefail
#
# show - MIGRATION STUB (temporary)
#
# `show` has been renamed to `show-me` to stop squatting the generic `show`
# verb on PATH (SHOW-58). This stub fails loudly so callers update their
# invocations instead of silently getting wrong behaviour. It does NOT
# delegate to show-me on purpose.
#
# Remove this stub in a later release once references are cleaned up.

cat >&2 <<'EOF'
show: this command has been renamed to `show-me`.

  Update your invocation:
    show <target>        ->  show-me <target>
    show --layout ... cmd:'...'  ->  show-me --layout ... cmd:'...'

`show` no longer runs. This is a deliberate, temporary migration error
(SHOW-58) -- it will be removed in a future release.
EOF

exit 127
